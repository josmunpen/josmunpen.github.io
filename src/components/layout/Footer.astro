---
import { siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";

const year = new Date().getFullYear();
// hideThemeCredit no longer used — credit block removed
---

<footer class="site-footer">
	<div class="left">
		<span>&copy; {year} {siteConfig.author}</span>
	</div>
	<div class="right">
		<a href={withBase("/rss.xml")}>RSS</a>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--hairline);
		padding-top: 22px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 16px;
		font-family: var(--font-sans);
		font-size: 12.5px;
		color: hsl(var(--theme-text) / 0.72);
		transition: border-color 0.35s ease;
	}
	.site-footer .left {
		display: flex;
		gap: 18px;
		align-items: center;
		flex-wrap: wrap;
	}
	.site-footer a {
		color: hsl(var(--theme-text-muted));
		transition: color 0.2s ease;
	}
	.site-footer a:hover {
		color: hsl(var(--theme-accent));
	}

	@media (max-width: 420px) {
		.site-footer {
			font-size: 11.5px;
			gap: 12px;
		}
	}
</style>
